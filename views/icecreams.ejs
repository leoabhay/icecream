<%- include('partials/header'); -%>

<main class="recipes-section">
  <div class="recipes-header">
    <h2>Signature <span style="color: var(--primary)">Flavors</span></h2>
    <p>Discover our range of handcrafted, artisanal ice cream creations.</p>
  </div>

  <ul class="recipes">
    <li class="recipe">
      <span class="badge">Classic</span>
      <img src="/img1.jpg" alt="Banana Split" />
      <h4>Banana Split</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Vanilla ice cream, Banana, Chocolate syrup, Whipped cream, Cherries</p>
      <div class="card-footer">
        <span class="price">Rs 200</span>
      </div>
    </li>
    <li class="recipe">
      <span class="badge" style="background: #b3e5fc; color: #0277bd"
        >Bestseller</span
      >
      <img src="/img2.jpg" alt="Tropical Paradise" />
      <h4>Tropical Paradise</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Coconut ice cream, Pineapple, Mango, Chopped nuts</p>
      <div class="card-footer">
        <span class="price">Rs 250</span>
      </div>
    </li>
    <li class="recipe">
      <span class="badge">Classic</span>
      <img src="/img3.jpg" alt="Peanut Butter Crunch" />
      <h4>Peanut Butter</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Peanut butter ice cream, Crushed peanuts, Chocolate chunks</p>
      <div class="card-footer">
        <span class="price">Rs 225</span>
      </div>
    </li>
    <li class="recipe">
      <span class="badge">Classic</span>
      <img src="/img4.jpg" alt="Mint Chocolate Chip" />
      <h4>Mint Choco</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Mint ice cream, Chocolate chips, Chocolate sauce</p>
      <div class="card-footer">
        <span class="price">Rs 200</span>
      </div>
    </li>
    <li class="recipe">
      <span class="badge" style="background: #f8bbd0; color: #c2185b"
        >Seasonal</span
      >
      <img src="/img5.jpg" alt="Strawberry Delight" />
      <h4>Strawberry</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Strawberry ice cream, Fresh strawberries, Cream, Wafer cone</p>
      <div class="card-footer">
        <span class="price">Rs 275</span>
      </div>
    </li>
    <li class="recipe">
      <span class="badge">Classic</span>
      <img src="/img6.jpg" alt="Cookie Monster" />
      <h4>Cookie Monster</h4>
      <span class="ingredients-label">Ingredients</span>
      <p>Cookies and cream ice cream, Crumbled chocolate cookies</p>
      <div class="card-footer">
        <span class="price">Rs 225</span>
      </div>
    </li>
  </ul>
</main>

<%- include('partials/footer'); -%>