<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Abhay Ice Creams | Handcrafted Happiness</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍦</text></svg>">
</head>
<body>
  <nav>
    <h1><a href="/">Abhay <span style="font-weight: 300">Ice Creams</span> 🍦</a></h1>
    <ul>
      <% if (user) { %>
        <li><span style="color: var(--primary); font-weight: 700">Hi, <%= user.email.split('@')[0] %>!</span></li>
        <li><a href="/icecreams">Flavors</a></li>
        <li><a href="/logout">Log out</a></li>
      <% } else { %>
        <li><a href="/icecreams">Flavors</a></li>
        <li><a href="/login">Log in</a></li>
        <li><a href="/signup" class="btn">Sign up</a></li>
      <% } %>
    </ul>
  </nav>